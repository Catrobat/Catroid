<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <CheckBox
        android:id="@+id/brick_checkbox"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:visibility="gone" />

    <org.catrobat.catroid.ui.BrickLayout
        android:id="@+id/brick_arc_layout"
        style="@style/BrickContainer.Motion.Big">

        <include layout="@layout/icon_brick_category_motion" />

        <TextView
            android:id="@+id/brick_arc_text_view"
            style="@style/BrickText.SingleLine"
            android:text="@string/arc_direction" />

        <Spinner
            android:id="@+id/brick_arc_spinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textDirection="locale" />

        <TextView
            style="@style/BrickText.SingleLine"
            android:text="@string/plot_with_radius" />

        <TextView
            android:id="@+id/brick_arc_edit_text1"
            style="@style/BrickEditText" />

        <TextView
            style="@style/BrickText.SingleLine"
            android:text="@string/plot_for_degrees" />

        <TextView
            android:id="@+id/brick_arc_edit_text2"
            style="@style/BrickEditText" />

        <TextView
            style="@style/BrickText"
            android:text="@string/degree_symbol" />

    </org.catrobat.catroid.ui.BrickLayout>

</LinearLayout>
