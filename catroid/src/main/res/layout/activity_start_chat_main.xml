<?xml version="1.0" encoding="utf-8"?>

<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".ChatBot.StartChatMainActivity"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <RelativeLayout
        android:background="#f5f5f5"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

         <com.google.android.material.card.MaterialCardView
             app:cardCornerRadius="0dp"
             app:cardElevation="5dp"
             android:id="@+id/top_bar"
             app:cardBackgroundColor="@color/colorPrimaryDark"
             android:layout_width="match_parent"
             android:layout_height="50dp">
            <RelativeLayout
                android:layout_marginEnd="10dp"
                android:layout_marginStart="10dp"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <TextView
                    android:id="@+id/show_description"
                    android:textStyle="bold"
                    android:textColor="#fff"
                    android:textSize="20sp"
                    android:text="CatroidChatBot"
                    android:layout_centerHorizontal="true"
                    android:layout_centerVertical="true"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <ImageView
                    android:id="@+id/delete_chats"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_delete_chats_button"
                    android:layout_width="30dp"
                    android:layout_height="30dp" />
            </RelativeLayout>
       </com.google.android.material.card.MaterialCardView>

        <androidx.recyclerview.widget.RecyclerView
            android:layout_below="@+id/top_bar"
            android:layout_above="@+id/bot_writing_view"
            android:id="@+id/recycler_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="10dp"
            android:scrollbars="none" />

        <ImageView
            android:layout_above="@id/card_view"
            android:id="@+id/bot_writing_view"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_marginStart="10dp"
            android:layout_marginBottom="5dp"
            android:src="@drawable/bot_icon"
            android:visibility="gone" />

      <com.google.android.material.card.MaterialCardView
          android:layout_alignParentBottom="true"
          android:id="@+id/card_view"
          app:cardBackgroundColor="#e6eced "
          android:layout_width="match_parent"
          android:layout_height="50dp">
            <LinearLayout
                android:background="#e6eced "
                android:layout_marginTop="1dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <EditText
                    android:id="@+id/message_input_view"
                    android:inputType="text"
                    android:maxLines="1"
                    android:scrollHorizontally="true"
                    android:textSize="20sp"
                    android:textColor="@color/black"
                    android:hint="Type a message"
                    android:layout_marginEnd="10dp"
                    android:layout_marginStart="10dp"
                    android:background="@null"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="match_parent" />

                <ImageView
                    android:id="@+id/message_send_button"
                    android:layout_marginEnd="10dp"
                    android:src="@drawable/ic_send_button"
                    android:layout_width="30dp"
                    android:layout_height="30dp" />

            </LinearLayout>
           </com.google.android.material.card.MaterialCardView>

    </RelativeLayout>


</androidx.coordinatorlayout.widget.CoordinatorLayout>
















