<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <solid android:color="#FFFFFF"/> <!-- White background for the bubble -->

    <!-- Define the corner radius -->
    <corners android:radius="16dp"/>

    <!-- Add padding inside the bubble -->
    <padding
        android:left="16dp"
        android:top="8dp"
        android:right="16dp"
        android:bottom="8dp"/>

    <!-- Define the shadow and outline -->
    <stroke
        android:width="2dp"
        android:color="#BDBDBD"/> <!-- Light grey border for the bubble -->

    <!-- Optional: Add a shadow for elevation effect -->
    <item>
        <shape>
            <solid android:color="#BDBDBD"/> <!-- Shadow color -->
            <corners android:radius="16dp"/>
            <padding
                android:bottom="2dp"
            android:right="2dp"
            android:top="-2dp"
            android:left="-2dp"/>
        </shape>
    </item>
</shape>

